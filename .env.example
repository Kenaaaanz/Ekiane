# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ENVIRONMENT=development

# Database (optional - uses SQLite by default)
DATABASE_URL=

# Paystack
PAYSTACK_PUBLIC_KEY=pk_test_placeholder
PAYSTACK_SECRET_KEY=sk_test_placeholder
PAYSTACK_SUBACCOUNT_CODE=
PAYSTACK_WEBHOOK_SECRET=replace-with-webhook-secret
PLATFORM_FEE_PERCENT=0

# Twilio SMS (optional - for admin notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
TWILIO_ADMIN_PHONE=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# Google Analytics
GOOGLE_TAG_MANAGER_ID=
GOOGLE_ANALYTICS_ID=

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=replace-with-secure-password
DEFAULT_FROM_EMAIL=noreply@example.com
ADMIN_EMAIL=admin@example.com

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_PHONE=+1234567890
TWILIO_ADMIN_PHONE=+254712345678
TWILIO_ORDER_ADMIN_SMS_TEMPLATE=New order #{order_id} from {customer_name} for {total} {currency}. Contact {phone} if needed.
TWILIO_ORDER_CUSTOMER_SMS_TEMPLATE=Thank you {customer_name}! Your order #{order_id} for {total} {currency} has been received. We will contact you soon.

# Site Configuration
SITE_URL=https://example.com
